# Copy this file to .env and fill in real values. NEVER commit .env itself.
MEDISCAN_DEBUG=false
MEDISCAN_LOG_LEVEL=INFO
MEDISCAN_MAX_UPLOAD_MB=20
MEDISCAN_ROUTER_MIN_CHARS_PER_PAGE=25
MEDISCAN_PREPROCESS_MIN_WIDTH=1000
MEDISCAN_RENDER_DPI=200
MEDISCAN_MAX_PDF_PAGES=50
MEDISCAN_GEMINI_API_KEY=your-gemini-key-here
MEDISCAN_GITHUB_MODELS_TOKEN=your-github-models-token-here
